AddType model/gltf-binary .glb
AddType model/gltf+json .gltf

<IfModule mod_headers.c>
    <FilesMatch "\.(glb|gltf)$">
        Header set Content-Type "model/gltf-binary"
        Header set Content-Disposition "inline"
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>
